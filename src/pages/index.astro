---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts');
const recentPosts = allPosts
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 5);

function formatDate(date: Date) {
  return new Intl.DateTimeFormat('zh-CN', { month: 'short', day: 'numeric' }).format(new Date(date));
}
---

<BaseLayout>
  <!-- Hero -->
  <section class="hero">
    <div class="greeting">小小产品人的学习日志</div>
    <h1 class="name">
      你好，我是 <em>Eric</em><br />
      在这里记录思考
    </h1>
    <p class="desc">
      <!-- TODO: 在这里写你的个人简介，2-3句话介绍你是谁、在关注什么 -->
      一个对产品、设计与人性充满好奇的探索者。这里有我的行业观察、实用教程，以及偶尔的生活随笔。不追求数量，只求每篇都说点真话。
    </p>
    <div class="tags">
      <!-- TODO: 修改为你关注的领域标签 -->
      <span class="tag">产品思维</span>
      <span class="tag">用户研究</span>
      <span class="tag">行业洞察</span>
      <span class="tag">工具方法</span>
      <span class="tag">生活随笔</span>
    </div>
    <a href="/posts" class="cta">
      阅读文章
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
        <path d="M1 7h12M8 2l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
  </section>

  <!-- Recent posts -->
  <section class="recent">
    <div class="section-label">最近更新</div>

    {recentPosts.map((post) => (
      <a href={`/posts/${post.slug}`} class="post-row fade-up">
        <div class="post-date">{formatDate(post.data.date)}</div>
        <div class="post-info">
          <div class="post-title">{post.data.title}</div>
          <div class="post-excerpt">{post.data.excerpt}</div>
        </div>
        <div class="post-tag">{post.data.category}</div>
      </a>
    ))}
  </section>
</BaseLayout>

<style>
  /* Hero */
  .hero {
    max-width: 760px;
    margin: 0 auto;
    padding: 80px 32px 64px;
  }

  .greeting {
    font-size: 0.72rem;
    color: var(--ink-3);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .greeting::before {
    content: '';
    display: inline-block;
    width: 20px;
    height: 1px;
    background: var(--ink-4);
  }

  .name {
    font-family: var(--serif);
    font-size: clamp(2.2rem, 5vw, 3.2rem);
    line-height: 1.15;
    color: var(--ink);
    margin-bottom: 20px;
    letter-spacing: -0.01em;
  }

  .name em {
    font-style: italic;
    color: var(--accent);
  }

  .desc {
    font-size: 1rem;
    color: var(--ink-2);
    line-height: 1.85;
    max-width: 520px;
    font-weight: 300;
    margin-bottom: 32px;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 40px;
  }

  .tag {
    background: var(--white);
    border: 1px solid var(--border);
    padding: 5px 14px;
    border-radius: 20px;
    font-size: 0.72rem;
    color: var(--ink-3);
    letter-spacing: 0.04em;
  }

  .cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--accent);
    color: var(--white);
    padding: 11px 22px;
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: background 0.2s;
    font-family: var(--sans);
  }

  .cta:hover { background: var(--accent-dark); }

  /* Recent */
  .recent {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 32px 80px;
  }

  .post-row {
    display: grid;
    grid-template-columns: 72px 1fr auto;
    gap: 0 24px;
    align-items: start;
    padding: 20px 0;
    border-bottom: 1px solid var(--border);
    cursor: pointer;
    transition: opacity 0.15s;
  }

  .post-row:hover { opacity: 0.7; }
  .post-row:hover .post-title { color: var(--accent); }
  .post-row:first-of-type { border-top: 1px solid var(--border); }

  .post-date {
    font-size: 0.7rem;
    color: var(--ink-4);
    font-weight: 300;
    padding-top: 3px;
    letter-spacing: 0.04em;
  }

  .post-title {
    font-family: var(--serif);
    font-size: 1.05rem;
    color: var(--ink);
    line-height: 1.4;
    margin-bottom: 4px;
    transition: color 0.2s;
  }

  .post-excerpt {
    font-size: 0.78rem;
    color: var(--ink-3);
    line-height: 1.6;
    font-weight: 300;
  }

  .post-tag {
    font-size: 0.62rem;
    color: var(--ink-3);
    border: 1px solid var(--border);
    padding: 3px 10px;
    border-radius: 12px;
    white-space: nowrap;
    align-self: center;
    letter-spacing: 0.04em;
  }

  @media (max-width: 600px) {
    .hero, .recent { padding-left: 20px; padding-right: 20px; }
    .post-row { grid-template-columns: 56px 1fr; }
    .post-tag { display: none; }
  }
</style>
